# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# vss-bridge NVM persistence — runtime state, not source.
# Default location is ./nvm/ relative to the bridge's CWD; override with
# the VSS_BRIDGE_NVM_PATH env var.
nvm/
